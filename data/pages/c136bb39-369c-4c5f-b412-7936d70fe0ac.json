    {
      "type": "paragraph",
      "children": [
        {
          "text": "Mehen ",
          "italic": true
        },
        {
          "text": "is thought to be a board game played by ancient Egyptians during the First to Sixth Dynasties. Various types of Mehen boards have been found throughout different tombs, suggesting that it was a popular game."
        }
      ]
    },
    {
      "type": "paragraph",
      "children": [
        {
          "text": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "children": [
        {
          "text": ""
        }
      ]
    },
    {
      "type": "image",
      "url": "https://upload.wikimedia.org/wikipedia/commons/0/09/-3000_Abydos_Spiel_der_Schlange_Mehen_anagoria.JPG",
      "caption": "Example of a Mehen board, held at the Ägyptisches Museum und Papyrussammlung, Berlin",
      "children": [
        {
          "text": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "children": [
        {
          "text": ""
        }
      ]
    },
    {
      "type": "paragraph",
      "children": [
        {
          "text": ""
        }
      ]
    },
    {
